<div class="armor-soak-panel" data-actor-id="{{actor.id}}">
  <div class="armor-soak-header">
    <h3><i class="fas fa-shield-alt"></i> {{localize "armor-soak-pool.panel.title"}}</h3>
    <label class="armor-soak-toggle">
      <span>{{localize "armor-soak-pool.fields.enabled"}}</span>
      <input type="checkbox" class="armor-soak-enabled" {{checked enabled}}>
    </label>
  </div>

  <div class="armor-soak-bar" role="meter" aria-valuemin="0" aria-valuemax="{{soak.max}}" aria-valuenow="{{soak.current}}">
    <div class="armor-soak-fill" style="width: {{pct}}%;"></div>
    <span>{{soak.current}} / {{soak.max}}</span>
  </div>

  <div class="armor-soak-grid">
    <label class="armor-soak-stat armor-soak-current-row">
      <strong>{{localize "armor-soak-pool.fields.current"}}</strong>
      <input class="armor-soak-current" type="number" value="{{soak.current}}" min="0" {{#unless allowOverflow}}max="{{soak.max}}"{{/unless}} step="1" {{#unless canAdjust}}disabled{{/unless}}>
    </label>
    <div class="armor-soak-stat"><strong>{{localize "armor-soak-pool.fields.max"}}</strong><span>{{soak.max}}</span></div>
    <div class="armor-soak-stat"><strong>{{localize "armor-soak-pool.fields.armorSoak"}}</strong><span>{{soak.armorSoak}}</span></div>
    <div class="armor-soak-stat"><strong>{{localize "armor-soak-pool.fields.naturalSoak"}}</strong><span>{{soak.naturalSoak}}</span></div>
    <div class="armor-soak-stat"><strong>{{localize "armor-soak-pool.fields.multiplier"}}</strong><span>{{soak.armorMultiplier}}×</span></div>
    <div class="armor-soak-stat"><strong>{{localize "armor-soak-pool.fields.armorAc"}}</strong><span>{{soak.armorAc}}</span></div>
  </div>

  <div class="armor-soak-actions">
    <button type="button" class="armor-soak-refill" {{#unless canRefill}}disabled{{/unless}}><i class="fas fa-battery-full"></i> {{localize "armor-soak-pool.actions.refill"}}</button>
  </div>
</div>
