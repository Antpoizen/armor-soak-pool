<div class="armor-soak-panel" data-actor-id="{{actor.id}}">
  <div class="armor-soak-header">
    <h3><i class="fas fa-shield-alt"></i> {{localize "armor-soak-pool.panel.title"}}</h3>
    <label class="armor-soak-toggle"><input type="checkbox" class="armor-soak-enabled" {{checked enabled}}> {{localize "armor-soak-pool.fields.enabled"}}</label>
  </div>

  <div class="armor-soak-bar" role="meter" aria-valuemin="0" aria-valuemax="{{soak.max}}" aria-valuenow="{{soak.current}}">
    <div class="armor-soak-fill" style="width: {{pct}}%;"></div>
    <span>{{soak.current}} / {{soak.max}}</span>
  </div>

  <div class="armor-soak-grid">
    <div><strong>{{localize "armor-soak-pool.fields.armorSoak"}}</strong><span>{{soak.armorSoak}}</span></div>
    <div><strong>{{localize "armor-soak-pool.fields.naturalSoak"}}</strong><span>{{soak.naturalSoak}}</span></div>
    <div><strong>{{localize "armor-soak-pool.fields.multiplier"}}</strong><span>{{soak.armorMultiplier}}×</span></div>
    <div><strong>{{localize "armor-soak-pool.fields.armorAc"}}</strong><span>{{soak.armorAc}}</span></div>
  </div>

  <div class="armor-soak-actions">
    <button type="button" class="armor-soak-recalculate"><i class="fas fa-sync-alt"></i> {{localize "armor-soak-pool.actions.recalculate"}}</button>
    <button type="button" class="armor-soak-refill" {{#unless canRefill}}disabled{{/unless}}><i class="fas fa-battery-full"></i> {{localize "armor-soak-pool.actions.refill"}}</button>
    <button type="button" class="armor-soak-adjust" {{#unless canAdjust}}disabled{{/unless}}><i class="fas fa-sliders-h"></i> {{localize "armor-soak-pool.actions.adjust"}}</button>
    <button type="button" class="armor-soak-damage" {{#unless canAdjust}}disabled{{/unless}}><i class="fas fa-bolt"></i> {{localize "armor-soak-pool.actions.damage"}}</button>
  </div>
</div>
